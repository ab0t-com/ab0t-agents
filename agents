# Default ignored directories for tree view
IGNORE_DIRS=".venv|venv|__pycache__|node_modules|.git|.idea|.vscode|.next|.nuxt|dist|build|target|.cache|.pytest_cache|.mypy_cache|.tox|.eggs|*.egg-info|.sass-cache|bower_components|vendor|.bundle|coverage|.nyc_output|.parcel-cache|.turbo|.svelte-kit"

# Tree drawing characters
T_BRANCH="├── "
T_LAST="└── "
T_PIPE="│   "
T_SPACE="    "

# Path decode cache directory and file
AGENTS_CACHE_DIR="$HOME/.ab0t/.agents"
DECODE_CACHE="$AGENTS_CACHE_DIR/decode_cache"

# Helper to convert project dir name to real path
# Claude Code encodes paths by replacing /, _, and . with -
# This makes decoding ambiguous, so we check what actually exists
decode_project_path() {
    local encoded="$1"

    # Check cache first
    if [ -f "$DECODE_CACHE" ]; then
        local cached
        cached=$(grep "^${encoded}|" "$DECODE_CACHE" 2>/dev/null | head -1 | cut -d'|' -f2-)
        if [ -n "$cached" ]; then
            echo "$cached"
            return
        fi
    fi

    # Try simple decode first (all dashes to slashes)
    local simple
    simple=$(echo "$encoded" | sed 's/^-/\//' | sed 's/-/\//g')
    if [ -d "$simple" ]; then
        # Cache and return
        mkdir -p "$AGENTS_CACHE_DIR"
        echo "${encoded}|${simple}" >> "$DECODE_CACHE"
        echo "$simple"
        return
    fi

    # Use Python to intelligently find the correct path
    local result
    result=$(ENCODED_PATH="$encoded" python3 -c '
import os

def find_real_path(encoded):
    """
    Claude Code encodes paths by replacing /, _, . with -
    This function finds the actual path by checking what exists on the filesystem.

    Strategy: Walk component by component, trying variations for each segment.
    """
    # Remove leading dash to get the encoded path
    if encoded.startswith("-"):
        encoded = encoded[1:]

    # Split by dash - each dash could be /, _, ., or literal -
    parts = encoded.split("-")

    def find_path_recursive(current_path, remaining_parts):
        """Recursively build path by checking what exists."""
        if not remaining_parts:
            return current_path if os.path.exists(current_path) else None

        # Try building candidates by combining consecutive parts
        # because a single original component might have had multiple dashes
        for num_parts in range(1, len(remaining_parts) + 1):
            segment_parts = remaining_parts[:num_parts]
            rest = remaining_parts[num_parts:]

            # Try different separators between the segment parts
            # For 1 part, just use it directly
            # For multiple parts, try joining with _, ., or -
            if num_parts == 1:
                candidates = [segment_parts[0]]
            else:
                # Generate combinations of separators
                candidates = generate_segment_candidates(segment_parts)

            for candidate in candidates:
                # Also try with leading . for hidden dirs/files
                test_candidates = [candidate]
                if not candidate.startswith("."):
                    test_candidates.append("." + candidate)

                for test in test_candidates:
                    test_path = os.path.join(current_path, test) if current_path else "/" + test

                    if os.path.exists(test_path):
                        if not rest:
                            return test_path
                        result = find_path_recursive(test_path, rest)
                        if result:
                            return result

        return None

    def generate_segment_candidates(parts):
        """Generate candidate segments by joining parts with _, ., or -"""
        if len(parts) == 1:
            return parts

        candidates = []
        # Try common patterns first for efficiency
        # All underscores
        candidates.append("_".join(parts))
        # All dots
        candidates.append(".".join(parts))
        # All dashes
        candidates.append("-".join(parts))
        # Mixed - for 2 parts this covers all combinations
        if len(parts) == 2:
            pass  # Already covered above
        elif len(parts) <= 4:
            # For small numbers of parts, try more combinations
            import itertools
            seps = ["_", ".", "-"]
            for sep_combo in itertools.product(seps, repeat=len(parts)-1):
                result = parts[0]
                for i, sep in enumerate(sep_combo):
                    result += sep + parts[i+1]
                if result not in candidates:
                    candidates.append(result)

        return candidates

    return find_path_recursive("", parts)

encoded = os.environ.get("ENCODED_PATH", "")
result = find_real_path(encoded)
if result:
    print(result)
else:
    # Fallback to simple decode if nothing found
    simple = "/" + encoded[1:].replace("-", "/") if encoded.startswith("-") else "/" + encoded.replace("-", "/")
    print(simple)
' 2>/dev/null)

    if [ -n "$result" ]; then
        # Cache and return
        mkdir -p "$AGENTS_CACHE_DIR"
        echo "${encoded}|${result}" >> "$DECODE_CACHE"
        echo "$result"
    else
        # Fallback
        echo "$encoded" | sed 's/^-/\//' | sed 's/-/\//g'
    fi
}

# Helper to encode a real path to Claude Code's project folder name
# Encodes /, _, and . as - to match Claude Code's behavior
encode_project_path() {
    local path="$1"
    # Remove leading slash, then replace /, _, . with -
    echo "$path" | sed 's/^\///' | sed 's/[\/_.@]/-/g'
}

# Get human readable time ago
time_ago() {
    local seconds=$1
    if [ $seconds -lt 60 ]; then
        echo "${seconds}s ago"
    elif [ $seconds -lt 3600 ]; then
        echo "$((seconds / 60))m ago"
    elif [ $seconds -lt 86400 ]; then
        echo "$((seconds / 3600))h ago"
    elif [ $seconds -lt 604800 ]; then
        echo "$((seconds / 86400))d ago"
    else
        echo "$((seconds / 604800))w ago"
    fi
}

# Get session info from jsonl file
# Extracts: summary (AI-generated), slug, branch, first user message
# Safe: file path passed via environment variable, not string interpolation
get_session_info() {
    local file="$1"

    SESSION_FILE="$file" python3 -c '
import os, json

def extract_user_text(content):
    """Extract text from user message content."""
    if isinstance(content, str):
        return content
    elif isinstance(content, list):
        for item in content:
            if isinstance(item, dict) and item.get("type") == "text":
                return item.get("text", "")
    return ""

try:
    file_path = os.environ.get("SESSION_FILE", "")
    summaries = []
    first_user_msg = None
    slug = None
    git_branch = None
    has_snapshots = False
    user_count = 0

    with open(file_path, "r") as f:
        for line in f:
            try:
                data = json.loads(line)
                record_type = data.get("type")

                # Extract slug (session name)
                if "slug" in data and not slug:
                    slug = data["slug"]

                # Extract git branch
                if "gitBranch" in data and data["gitBranch"] and not git_branch:
                    git_branch = data["gitBranch"]

                # Collect AI-generated summaries (prefer most recent)
                if record_type == "summary":
                    summary = data.get("summary", "").strip()
                    if summary:
                        summaries.append(summary)
                # Capture first user message as fallback
                elif record_type == "user":
                    user_count += 1
                    if first_user_msg is None:
                        text = extract_user_text(data.get("message", {}).get("content", ""))
                        if text:
                            first_user_msg = text
                elif record_type == "file-history-snapshot":
                    has_snapshots = True
            except json.JSONDecodeError:
                pass

    # Build result: prefer summary > first user msg > slug > branch > snapshot notice
    result = ""
    if summaries:
        result = summaries[-1]  # Most recent AI summary
    elif first_user_msg:
        result = first_user_msg
    elif slug:
        result = f"[{slug}]"  # Use slug as session name
    elif git_branch:
        result = f"[branch: {git_branch}]"
    elif has_snapshots:
        result = "[file snapshots only - no conversation]"
    else:
        result = "[empty session]"

    # Clean up and truncate
    result = " ".join(result.split())[:70]
    # Remove markdown headers and quotes (but not our bracket tags)
    if not result.startswith("["):
        result = result.lstrip("#").lstrip("\"").rstrip("\"").strip()
    print(result)
except Exception as e:
    print(f"[error: {e}]")
' 2>/dev/null || true
}

# Get detailed session summary
# Prioritizes AI-generated summary, includes conversation preview
# Safe: file path passed via environment variable, not string interpolation
get_session_summary() {
    local file="$1"
    local max_lines="${2:-3}"

    SESSION_FILE="$file" MAX_LINES="$max_lines" python3 -c '
import os, json

def extract_text(content):
    if isinstance(content, str):
        return content
    elif isinstance(content, list):
        for item in content:
            if isinstance(item, dict) and item.get("type") == "text":
                return item.get("text", "")
    return ""

try:
    file_path = os.environ.get("SESSION_FILE", "")
    max_lines = int(os.environ.get("MAX_LINES", "3"))

    summaries = []
    messages = []

    with open(file_path, "r") as f:
        for line in f:
            try:
                data = json.loads(line)
                # Collect AI-generated summaries
                if data.get("type") == "summary":
                    summary = data.get("summary", "").strip()
                    if summary:
                        summaries.append(summary)
                elif data.get("type") == "user":
                    text = extract_text(data.get("message", {}).get("content", ""))
                    if text:
                        text = " ".join(text.split())[:80]
                        messages.append(("user", text))
                elif data.get("type") == "assistant":
                    msg = data.get("message", {})
                    if isinstance(msg, dict):
                        content = msg.get("content", [])
                        if isinstance(content, list):
                            for item in content:
                                if isinstance(item, dict) and item.get("type") == "text":
                                    text = " ".join(item.get("text", "").split())[:80]
                                    if text and not text.startswith("<"):
                                        messages.append(("assistant", text))
                                        break
            except: pass

    # Show AI-generated summary first (if available)
    if summaries:
        summary = summaries[-1]  # Most recent
        summary = summary.lstrip("#").strip().strip("\"")
        print(f"📋 {summary[:75]}")

    # Show conversation preview
    count = 0
    for role, text in messages[:max_lines * 2]:
        if count >= max_lines:
            break
        if role == "user":
            print(f"USR: {text[:70]}")
            count += 1
        elif count > 0:
            print(f"AI:  {text[:70]}")
except:
    pass
' 2>/dev/null
}

# Get git branch from session
get_session_branch() {
    local file="$1"
    head -10 "$file" 2>/dev/null | grep -o '"gitBranch":"[^"]*"' | head -1 | cut -d'"' -f4
}

# Tree command - filesystem tree with session annotations on directories
# Shows normal file tree but annotates any directory that has Claude sessions
cmd_tree() {
    local target="${1:-.}"
    local depth="${2:-4}"
    local show_all_files=false

    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -d|--depth) depth="$2"; shift 2 ;;
            -a|--all) show_all_files=true; shift ;;
            *)
                if [[ ! "$1" =~ ^- ]]; then
                    target="$1"
                fi
                shift
                ;;
        esac
    done

    local real_path=""

    # Resolve target
    if [[ "$target" =~ ^[0-9]+$ ]]; then
        # Number from agents list
        if [ -f "$AGENTS_CACHE_DIR/projects_cache" ]; then
            local project_dir
            project_dir=$(sed -n "${target}p" "$AGENTS_CACHE_DIR/projects_cache")
            if [ -n "$project_dir" ]; then
                local project_name
                project_name=$(basename "$project_dir")
                real_path=$(decode_project_path "$project_name")
            fi
        fi
    elif [ "$target" = "." ]; then
        real_path=$(pwd)
    else
        real_path="$target"
    fi

    if [ -z "$real_path" ] || [ ! -d "$real_path" ]; then
        echo -e "${RED}Could not resolve target: $target${RESET}"
        exit 1
    fi

    echo -e "${BOLD}${CYAN}Claude Code Project Tree${RESET}"
    echo -e "${DIM}────────────────────────────────────────────────────${RESET}"
    echo

    # Use Python to walk the tree and annotate directories with session info
    TARGET_PATH="$real_path" PROJECTS_DIR="$PROJECTS_DIR" IGNORE_DIRS="$IGNORE_DIRS" \
    MAX_DEPTH="$depth" SHOW_ALL_FILES="$show_all_files" python3 -c '
import os, time, glob

target = os.environ["TARGET_PATH"]
projects_dir = os.environ["PROJECTS_DIR"]
ignore_dirs_str = os.environ.get("IGNORE_DIRS", "")
max_depth = int(os.environ.get("MAX_DEPTH", "4"))
show_all_files = os.environ.get("SHOW_ALL_FILES", "false") == "true"
# Max files to show per directory in compact mode (dirs always shown)
MAX_FILES_PREVIEW = 2

# Parse ignore patterns
ignore_patterns = set(ignore_dirs_str.split("|")) if ignore_dirs_str else set()

# ANSI colors
BLUE = "\033[0;34m"
CYAN = "\033[0;36m"
MAGENTA = "\033[0;35m"
GREEN = "\033[0;32m"
YELLOW = "\033[1;33m"
GRAY = "\033[0;90m"
WHITE = "\033[1;37m"
BOLD = "\033[1m"
DIM = "\033[2m"
RESET = "\033[0m"

# Tree characters
T_BRANCH = "\u251c\u2500\u2500 "
T_LAST   = "\u2514\u2500\u2500 "
T_PIPE   = "\u2502   "
T_SPACE  = "    "

def time_ago(seconds):
    if seconds < 60:
        return f"{seconds}s ago"
    elif seconds < 3600:
        return f"{seconds // 60}m ago"
    elif seconds < 86400:
        return f"{seconds // 3600}h ago"
    elif seconds < 604800:
        return f"{seconds // 86400}d ago"
    else:
        return f"{seconds // 604800}w ago"

def encode_path(path):
    """Encode a real path to Claude Code project folder name."""
    encoded = path.lstrip("/")
    result = []
    for ch in encoded:
        if ch in "/_. @":
            result.append("-")
        else:
            result.append(ch)
    return "-" + "".join(result)

def get_session_info(project_folder):
    """Get session count and most recent mtime for a project folder."""
    if not os.path.isdir(project_folder):
        return 0, 0
    count = 0
    latest_mtime = 0
    try:
        for f in os.listdir(project_folder):
            if f.endswith(".jsonl") and not f.startswith("agent-"):
                count += 1
                fpath = os.path.join(project_folder, f)
                mtime = os.path.getmtime(fpath)
                if mtime > latest_mtime:
                    latest_mtime = mtime
    except OSError:
        pass
    return count, latest_mtime

# Build a lookup of all project dirs under target path
# Map: real_path -> (session_count, latest_mtime)
session_map = {}
if os.path.isdir(projects_dir):
    for entry in os.listdir(projects_dir):
        proj_path = os.path.join(projects_dir, entry)
        if not os.path.isdir(proj_path):
            continue
        count, mtime = get_session_info(proj_path)
        if count > 0:
            session_map[entry] = (count, mtime)

def should_ignore(name):
    """Check if a file/directory name matches ignore patterns."""
    for pattern in ignore_patterns:
        if pattern.startswith("*"):
            if name.endswith(pattern[1:]):
                return True
        elif name == pattern:
            return True
    return False

def get_dir_annotation(dir_path):
    """Check if a directory has Claude sessions and return annotation string."""
    encoded = encode_path(dir_path)
    info = session_map.get(encoded)
    if info:
        count, mtime = info
        now = time.time()
        age = int(now - mtime)
        age_str = time_ago(age)
        # Color based on recency
        if age < 3600:
            color = GREEN
        elif age < 86400:
            color = YELLOW
        else:
            color = GRAY
        plural = "s" if count != 1 else ""
        return f"  {DIM}({RESET}{MAGENTA}{count} session{plural}{RESET} {color}{age_str}{RESET}{DIM}){RESET}"
    return ""

def file_color(name):
    """Get color for a file based on extension."""
    ext = name.rsplit(".", 1)[-1] if "." in name else ""
    if ext in ("py",):
        return GREEN
    elif ext in ("js", "ts", "jsx", "tsx"):
        return YELLOW
    elif ext in ("json", "yaml", "yml", "toml"):
        return CYAN
    elif ext in ("md", "txt", "rst"):
        return WHITE
    elif ext in ("sh", "bash"):
        return CYAN
    return RESET

def draw_tree(dir_path, prefix, current_depth):
    """Recursively draw a tree with session annotations.
    Shows all directories but only a preview of files per directory
    unless --all is specified."""
    if current_depth > max_depth:
        return

    try:
        entries = sorted(os.listdir(dir_path))
    except PermissionError:
        return

    # Separate dirs and files, filtering ignored/hidden
    dirs = []
    files = []
    for name in entries:
        if should_ignore(name):
            continue
        if name.startswith("."):
            continue
        full_path = os.path.join(dir_path, name)
        if os.path.isdir(full_path):
            dirs.append(name)
        else:
            files.append(name)

    # In compact mode, limit files shown
    if show_all_files:
        shown_files = files
        hidden_file_count = 0
    else:
        shown_files = files[:MAX_FILES_PREVIEW]
        hidden_file_count = len(files) - len(shown_files)

    # Combined list: all dirs + limited files + optional "more" indicator
    items = [(d, True) for d in dirs] + [(f, False) for f in shown_files]
    has_more = hidden_file_count > 0
    total = len(items) + (1 if has_more else 0)

    for idx, (name, is_dir) in enumerate(items):
        is_last = (idx == len(items) - 1) and not has_more
        connector = T_LAST if is_last else T_BRANCH
        next_prefix = prefix + (T_SPACE if is_last else T_PIPE)

        full_path = os.path.join(dir_path, name)

        if is_dir:
            annotation = get_dir_annotation(full_path)
            print(f"{prefix}{connector}{BLUE}{name}/{RESET}{annotation}")
            draw_tree(full_path, next_prefix, current_depth + 1)
        else:
            color = file_color(name)
            print(f"{prefix}{connector}{color}{name}{RESET}")

    # Show hidden file count
    if has_more:
        print(f"{prefix}{T_LAST}{DIM}... ({hidden_file_count} more files){RESET}")

# Header with annotation for root
root_annotation = get_dir_annotation(target)
print(f"{BOLD}{CYAN}{target}{RESET}{root_annotation}")

draw_tree(target, "", 1)
'

    echo
    echo -e "${DIM}Use -a to show all files, -d N to set depth${RESET}"
}

# Legacy tree command - single project view with session details
# Usage: agents tree2 [path|num]
cmd_tree_project() {
    local target="${1:-.}"
    local depth="${2:-4}"
    local show_files=true
    local show_hidden=false

    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -d|--depth) depth="$2"; shift 2 ;;
            -a|--all) show_hidden=true; shift ;;
            --no-files) show_files=false; shift ;;
            *)
                if [[ ! "$1" =~ ^- ]]; then
                    target="$1"
                fi
                shift
                ;;
        esac
    done

    local real_path=""
    local project_dir=""

    # Resolve target
    if [[ "$target" =~ ^[0-9]+$ ]]; then
        # Number from agents list
        if [ -f "$AGENTS_CACHE_DIR/projects_cache" ]; then
            project_dir=$(sed -n "${target}p" "$AGENTS_CACHE_DIR/projects_cache")
            if [ -n "$project_dir" ]; then
                local project_name=$(basename "$project_dir")
                real_path=$(decode_project_path "$project_name")
            fi
        fi
    elif [ "$target" = "." ]; then
        real_path=$(pwd)
        local encoded=$(encode_project_path "$real_path")
        project_dir="$PROJECTS_DIR/-$encoded"
    else
        real_path="$target"
        local encoded=$(encode_project_path "$target")
        project_dir="$PROJECTS_DIR/-$encoded"
    fi

    if [ -z "$real_path" ]; then
        echo -e "${RED}Could not resolve target: $target${RESET}"
        exit 1
    fi

    # Header
    echo -e "${BOLD}${CYAN}$real_path${RESET}"

    # Check if we have sessions
    local has_sessions=false
    if [ -d "$project_dir" ]; then
        local session_count=$(find "$project_dir" -maxdepth 1 -name "*.jsonl" ! -name "agent-*" 2>/dev/null | wc -l)
        if [ "$session_count" -gt 0 ]; then
            has_sessions=true
        fi
    fi

    # Show sessions section
    if [ "$has_sessions" = true ]; then
        echo -e "${T_BRANCH}${BOLD}${MAGENTA}.claude-sessions/${RESET} ${DIM}($session_count sessions)${RESET}"

        local session_idx=0
        local session_files=()

        # Collect session files
        while IFS= read -r line; do
            session_files+=("$line")
        done < <(find_with_mtime "$project_dir" -maxdepth 1 -name "*.jsonl" ! -name "agent-*" | sort -rn | head -8)

        local total_sessions=${#session_files[@]}

        for line in "${session_files[@]}"; do
            session_idx=$((session_idx + 1))
            local mtime=$(echo "$line" | cut -d' ' -f1)
            local file=$(echo "$line" | cut -d' ' -f2-)
            local filename=$(basename "$file")
            local session_id="${filename%.jsonl}"

            local now=$(date +%s)
            local age=$((now - mtime))
            local time_str=$(time_ago $age)
            local size=$(du -h "$file" 2>/dev/null | cut -f1)
            local branch=$(get_session_branch "$file")

            # Color based on recency
            local time_color=$GRAY
            [ $age -lt 3600 ] && time_color=$GREEN
            [ $age -lt 86400 ] && [ $age -ge 3600 ] && time_color=$YELLOW

            # Tree connector
            local connector="$T_PIPE$T_BRANCH"
            local sub_prefix="$T_PIPE$T_PIPE"
            if [ $session_idx -eq $total_sessions ]; then
                connector="$T_PIPE$T_LAST"
                sub_prefix="$T_PIPE$T_SPACE"
            fi

            # Session header
            printf "${connector}${YELLOW}[%d]${RESET} ${WHITE}${session_id:0:8}${RESET}" "$session_idx"
            printf " ${time_color}%-8s${RESET}" "$time_str"
            printf " ${DIM}%s${RESET}" "$size"
            if [ -n "$branch" ]; then
                printf " ${CYAN}⎇ %s${RESET}" "$branch"
            fi
            echo

            # Session summary (first user message)
            local summary=$(get_session_info "$file")
            if [ -n "$summary" ]; then
                # Truncate to fit
                [ ${#summary} -gt 65 ] && summary="${summary:0:62}..."
                printf "${sub_prefix}${GRAY}\"${summary}\"${RESET}\n"
            fi
        done

        # Show if more sessions exist
        if [ "$session_count" -gt 8 ]; then
            echo -e "${T_PIPE}${T_SPACE}${DIM}... and $((session_count - 8)) more sessions${RESET}"
        fi
    fi

    # Show project files if directory exists
    if [ -d "$real_path" ] && [ "$show_files" = true ]; then
        local tree_prefix="$T_LAST"
        [ "$has_sessions" = true ] && tree_prefix="$T_BRANCH"

        echo -e "${tree_prefix}${BOLD}${BLUE}files/${RESET}"

        # Build ignore pattern for find
        local ignore_pattern=""
        IFS='|' read -ra IGNORE_ARRAY <<< "$IGNORE_DIRS"
        for dir in "${IGNORE_ARRAY[@]}"; do
            ignore_pattern="$ignore_pattern -name '$dir' -prune -o"
        done

        # Use tree if available, otherwise custom implementation
        if command -v tree &> /dev/null; then
            # Build tree ignore pattern
            local tree_ignore=$(echo "$IGNORE_DIRS" | sed 's/|/ -I /g')
            tree -C -L "$depth" -I "$tree_ignore" --noreport "$real_path" 2>/dev/null | tail -n +2 | sed "s/^/    /"
        else
            # Fallback: custom tree-like output
            _draw_tree "$real_path" "" "$depth" 1
        fi

        # Count hidden items
        if [ "$show_hidden" = false ]; then
            local hidden_count=0
            for dir in "${IGNORE_ARRAY[@]}"; do
                if [ -d "$real_path/$dir" ]; then
                    hidden_count=$((hidden_count + 1))
                fi
            done
            if [ $hidden_count -gt 0 ]; then
                echo -e "    ${DIM}($hidden_count directories hidden: .venv, node_modules, etc.)${RESET}"
            fi
        fi
    fi

    echo

    # Resume hints
    if [ "$has_sessions" = true ]; then
        echo -e "${DIM}Quick resume: ${GREEN}cd $real_path && claude -c${RESET}"
    fi
}

# Helper function to draw tree (fallback if tree command not available)
_draw_tree() {
    local dir="$1"
    local prefix="$2"
    local max_depth="$3"
    local current_depth="$4"

    [ "$current_depth" -gt "$max_depth" ] && return

    local items=()
    local count=0

    # Collect visible items
    while IFS= read -r -d '' item; do
        local name=$(basename "$item")

        # Skip ignored directories
        local skip=false
        IFS='|' read -ra IGNORE_ARRAY <<< "$IGNORE_DIRS"
        for pattern in "${IGNORE_ARRAY[@]}"; do
            if [[ "$name" == $pattern ]]; then
                skip=true
                break
            fi
        done

        [ "$skip" = true ] && continue
        [ "${name:0:1}" = "." ] && continue  # Skip hidden by default

        items+=("$item")
        count=$((count + 1))
        [ $count -ge 20 ] && break  # Limit items per level
    done < <(find "$dir" -maxdepth 1 -mindepth 1 -print0 2>/dev/null | sort -z)

    local total=${#items[@]}
    local idx=0

    for item in "${items[@]}"; do
        idx=$((idx + 1))
        local name=$(basename "$item")
        local connector="$T_BRANCH"
        local next_prefix="${prefix}$T_PIPE"

        if [ $idx -eq $total ]; then
            connector="$T_LAST"
            next_prefix="${prefix}$T_SPACE"
        fi

        if [ -d "$item" ]; then
            echo -e "    ${prefix}${connector}${BLUE}${name}/${RESET}"
            _draw_tree "$item" "$next_prefix" "$max_depth" $((current_depth + 1))
        else
            # Color files by extension
            local color="$RESET"
            case "${name##*.}" in
                py) color="$GREEN" ;;
                js|ts|jsx|tsx) color="$YELLOW" ;;
                json|yaml|yml|toml) color="$CYAN" ;;
                md|txt|rst) color="$WHITE" ;;
                sh|bash) color="$MAGENTA" ;;
                *) color="$RESET" ;;
            esac
            echo -e "    ${prefix}${connector}${color}${name}${RESET}"
        fi
    done
}

