# Show sessions for a specific project (delegates to Python with adapters)
# Accepts: number (position from last list), letter (stable ID), or path
cmd_show() {
    local target="${1:-.}"

    # If target is a number or letter, resolve from projects cache
    if [[ "$target" =~ ^[0-9]+$ ]] || [[ "$target" =~ ^[a-z]{1,2}$ ]]; then
        if [ -f "$AGENTS_CACHE_DIR/projects_cache.json" ]; then
            local resolved
            resolved=$(TARGET_KEY="$target" python3 -c '
import os, json
try:
    with open(os.path.expanduser("~/.ab0t/.agents/projects_cache.json")) as f:
        projects = json.load(f)
    key = os.environ["TARGET_KEY"]
    # Try as number first
    if key.isdigit():
        idx = int(key) - 1
        if 0 <= idx < len(projects):
            print(projects[idx]["path"])
    else:
        # Try as letter ID
        for p in projects:
            if p.get("letter") == key:
                print(p["path"])
                break
except: pass
' 2>/dev/null)
            if [ -n "$resolved" ]; then
                target="$resolved"
            else
                echo -e "${RED}Invalid project number/letter. Run 'agents list' first.${RESET}"
                exit 1
            fi
        else
            echo -e "${RED}Run 'agents list' first.${RESET}"
            exit 1
        fi
    fi

    TARGET="$target" python3 "$SCRIPT_DIR/scripts/session-show.py"
}

# Quick resume command - reads from sessions_cache.json (supports multiple agents)
cmd_resume() {
    local target="${1:-}"
    local query="${2:-}"

    if [ -z "$target" ]; then
        echo -e "${RED}Usage: agents resume <session-num> [query]${RESET}"
        exit 1
    fi

    local session_id=""
    local project_path=""
    local agent_name="claude"

    if [[ "$target" =~ ^[0-9]+$ ]]; then
        # Look up from JSON cache (new format from session-show.py)
        if [ -f "$AGENTS_CACHE_DIR/sessions_cache.json" ]; then
            local resolved
            resolved=$(TARGET_NUM="$target" python3 -c '
import os, json
try:
    with open(os.path.expanduser("~/.ab0t/.agents/sessions_cache.json")) as f:
        sessions = json.load(f)
    idx = int(os.environ["TARGET_NUM"]) - 1
    if 0 <= idx < len(sessions):
        s = sessions[idx]
        print(s["session_id"] + "|" + s["path"] + "|" + s["agent"])
except: pass
' 2>/dev/null)
            if [ -n "$resolved" ]; then
                session_id=$(echo "$resolved" | cut -d'|' -f1)
                project_path=$(echo "$resolved" | cut -d'|' -f2)
                agent_name=$(echo "$resolved" | cut -d'|' -f3)
            fi
        # Fallback: old plain-text cache
        elif [ -f "$AGENTS_CACHE_DIR/sessions_cache" ] && [ -f "$AGENTS_CACHE_DIR/path_cache" ]; then
            session_id=$(sed -n "${target}p" "$AGENTS_CACHE_DIR/sessions_cache")
            project_path=$(cat "$AGENTS_CACHE_DIR/path_cache")
        fi
    else
        session_id="$target"
        project_path=$(pwd)
    fi

    if [ -z "$session_id" ] || [ -z "$project_path" ]; then
        echo -e "${RED}Could not find session. Run 'agents show' first.${RESET}"
        exit 1
    fi

    echo -e "${CYAN}Resuming ${BOLD}${agent_name}${RESET}${CYAN} session ${MAGENTA}${session_id:0:8}${RESET} in ${BLUE}$project_path${RESET}"
    echo

    case "$agent_name" in
        codex)
            if [ -n "$query" ]; then
                echo -e "${DIM}cd \"$project_path\" && codex resume \"$session_id\" \"$query\"${RESET}"
                cd "$project_path" && codex resume "$session_id" "$query"
            else
                echo -e "${DIM}cd \"$project_path\" && codex resume \"$session_id\"${RESET}"
                cd "$project_path" && codex resume "$session_id"
            fi
            ;;
        *)
            if [ -n "$query" ]; then
                echo -e "${DIM}cd \"$project_path\" && claude -r \"$session_id\" \"$query\"${RESET}"
                cd "$project_path" && claude -r "$session_id" "$query"
            else
                echo -e "${DIM}cd \"$project_path\" && claude -r \"$session_id\"${RESET}"
                cd "$project_path" && claude -r "$session_id"
            fi
            ;;
    esac
}

# Quick resume from project list - resolves letter/number from projects_cache.json,
# cd's into the project dir, and resumes the last session (claude -c / codex resume --last)
cmd_quick_resume() {
    local target="${1:-}"

    if [ -z "$target" ]; then
        echo -e "${RED}Usage: agents go <letter|num>${RESET}"
        echo -e "${DIM}Resume the last session for a project from the agents list.${RESET}"
        exit 1
    fi

    if ! [ -f "$AGENTS_CACHE_DIR/projects_cache.json" ]; then
        echo -e "${RED}Run 'agents' first to build the project list.${RESET}"
        exit 1
    fi

    local resolved
    resolved=$(TARGET_KEY="$target" python3 -c '
import os, json
try:
    with open(os.path.expanduser("~/.ab0t/.agents/projects_cache.json")) as f:
        projects = json.load(f)
    key = os.environ["TARGET_KEY"]
    match = None
    if key.isdigit():
        idx = int(key) - 1
        if 0 <= idx < len(projects):
            match = projects[idx]
    else:
        for p in projects:
            if p.get("letter") == key:
                match = p
                break
    if match:
        # Pick primary agent: prefer claude, fall back to first available
        agents = match.get("agents", ["claude"])
        agent = "claude" if "claude" in agents else agents[0]
        print(match["path"] + "|" + agent)
except: pass
' 2>/dev/null)

    if [ -z "$resolved" ]; then
        echo -e "${RED}Invalid project letter/number. Run 'agents' first.${RESET}"
        exit 1
    fi

    local project_path agent_name
    project_path=$(echo "$resolved" | cut -d'|' -f1)
    agent_name=$(echo "$resolved" | cut -d'|' -f2)

    echo -e "${CYAN}Resuming last ${BOLD}${agent_name}${RESET}${CYAN} session in ${YELLOW}$project_path${RESET}"
    echo

    case "$agent_name" in
        codex)
            echo -e "${DIM}cd \"$project_path\" && codex resume --last${RESET}"
            cd "$project_path" && sleep 1 && codex resume --last
            ;;
        *)
            echo -e "${DIM}cd \"$project_path\" && claude -c${RESET}"
            cd "$project_path" && sleep 1 && claude -c
            ;;
    esac
}

# Quick stats - delegates to scripts/session-stats.py
cmd_stats() {
    # Compute combined size across all known agent data dirs
    local total_size_bytes=0
    for dir in "$PROJECTS_DIR" "$HOME/.codex/sessions"; do
        if [ -d "$dir" ]; then
            local sz
            sz=$(du -sb "$dir" 2>/dev/null | cut -f1)
            total_size_bytes=$((total_size_bytes + sz))
        fi
    done
    local total_size
    total_size=$(echo "$total_size_bytes" | numfmt --to=iec 2>/dev/null || echo "${total_size_bytes}B")
    local startups=""
    if [ -f "$CLAUDE_JSON" ]; then
        startups=$(CLAUDE_JSON_PATH="$CLAUDE_JSON" python3 -c '
import os, json
try:
    with open(os.environ["CLAUDE_JSON_PATH"]) as f:
        data = json.load(f)
    print(data.get("numStartups", 0))
except: print("0")
' 2>/dev/null) || true
    fi

    PROJECTS_DIR="$PROJECTS_DIR" TOTAL_SIZE="$total_size" \
    TOTAL_STARTUPS="${startups:-0}" python3 "$SCRIPT_DIR/scripts/session-stats.py"
}

