# agents - Claude Code Session Browser
# .gitignore

# =============================================================================
# Backups created by install.sh
# =============================================================================
*.backup.*

# =============================================================================
# OS generated files
# =============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# =============================================================================
# Editor / IDE
# =============================================================================
# VSCode
.vscode/
*.code-workspace

# JetBrains
.idea/
*.iml
*.iws
*.ipr

# Vim
*.swp
*.swo
*.swn
*~
.netrwhist

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc
auto-save-list
tramp
.\#*

# Sublime Text
*.sublime-workspace
*.sublime-project

# =============================================================================
# Testing / Development
# =============================================================================
# Test output
test-output/
*.test.log

# Coverage
coverage/
*.lcov

# Temp files
tmp/
temp/
*.tmp
*.temp

# =============================================================================
# Build artifacts
# =============================================================================
dist/
build/
out/

# =============================================================================
# Package managers (if we ever add them)
# =============================================================================
node_modules/
vendor/
.bundle/

# =============================================================================
# Environment
# =============================================================================
.env
.env.local
.env.*.local
*.env

# =============================================================================
# Logs
# =============================================================================
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# =============================================================================
# Archives (keep releases clean)
# =============================================================================
*.tar.gz
*.zip
*.tgz

# But allow release archives in releases/ dir
!releases/*.tar.gz
!releases/*.zip
!releases/*.sha256

# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
*.egg
.eggs/

# =============================================================================
# Agent data / sessions
# =============================================================================
.claude-data/
