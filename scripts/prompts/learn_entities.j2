     "confidence": "high|medium|low",
     "category": "style|tooling|workflow|testing|architecture",
     "evidence": "quote or paraphrase from the session proving this"}
  ],
  "tools_and_stack": [
    {"name": "exact tool/library name",
     "role": "what it was used for in this context",
     "sentiment": "preferred|used|mentioned|rejected"}
  ],
  "coding_patterns": [
    {"pattern": "description of the coding pattern or style",
     "frequency": "once|recurring"}
  ],
  "explicit_instructions": [
